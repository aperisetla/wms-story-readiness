# ============================================================================
# WMS Story Readiness Analyzer — environment variables template
# Copy this file to `.env` and populate. Never commit the real `.env`.
# ============================================================================

# ---------- Jira Cloud ------------------------------------------------------
# Base URL of your Jira Cloud site (no trailing slash). Must be the production
# tenant; sandbox URLs are rejected at runtime unless ALLOW_SANDBOX=1 is set.
JIRA_BASE_URL=https://ashley-furniture-team.atlassian.net

# Atlassian account email used to authenticate
JIRA_EMAIL=service.account@ashleyfurniture.com

# API token generated at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=replace-with-atlassian-api-token

# Comma-separated list of project keys to scan
JIRA_PROJECTS=WW,WR

# Label used to flag stories ready for readiness analysis
JIRA_LABEL=Estimate

# Custom field id that stores Acceptance Criteria (string or ADF). Leave blank
# to fall back to description-only analysis.
# For the WW/WR projects this is customfield_10091 (observed from API).
JIRA_AC_FIELD=customfield_10091

# ---------- LLM provider ----------------------------------------------------
# Supported: github_models (default, free via GitHub), openai, azure, anthropic
LLM_PROVIDER=github_models

# --- GitHub Models (default, free with a GitHub PAT / Actions GITHUB_TOKEN) ---
# Create a fine-grained PAT with "Models: Read" permission at
# https://github.com/settings/personal-access-tokens/new
# In GitHub Actions, the built-in GITHUB_TOKEN works automatically when the
# workflow declares `permissions: models: read`.
GH_MODELS_TOKEN=
GH_MODELS_ENDPOINT=https://models.github.ai/inference
GH_MODELS_MODEL=openai/gpt-4o-mini

# --- OpenAI (public cloud) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Azure OpenAI (enterprise) ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ---------- Runtime ---------------------------------------------------------
# Directory where markdown reports will be written
OUTPUT_DIR=./output

# Max issues to process per run (safety cap; 0 = no cap)
MAX_ISSUES=0

# Comma-separated issue keys to skip
EXCLUDE_KEYS=

# Set to 1 to post analyses back as Jira comments (dry-run by default)
POST_COMMENTS=0
